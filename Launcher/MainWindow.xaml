<Window x:Class="SeapowerMultiplayer.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seapower Multiplayer Launcher"
        Width="520" Height="580"
        MinWidth="480" MinHeight="540"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBg}">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Update Banner -->
                <RowDefinition Height="Auto"/>
                <!-- Game Path -->
                <RowDefinition Height="Auto"/>
                <!-- Separator -->
                <RowDefinition Height="Auto"/>
                <!-- Network Settings -->
                <RowDefinition Height="*"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
                <RowDefinition Height="Auto"/>
                <!-- Status -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock x:Name="TxtVersion"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"/>
                    <TextBlock Text=" BETA"
                           Foreground="{StaticResource ErrorRed}"
                           FontSize="12"
                           FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="Seapower Multiplayer"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="22"
                       FontWeight="Bold"/>
            </DockPanel>

            <!-- Update Banner (hidden by default) -->
            <Border x:Name="PnlUpdate" Grid.Row="1" Visibility="Collapsed"
                Background="#30FFA500" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <DockPanel>
                    <Button x:Name="BtnUpdate" Content="Update Now"
                        DockPanel.Dock="Right" Padding="12,4"
                        Click="BtnUpdate_Click"/>
                    <TextBlock x:Name="TxtUpdateInfo"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- Game Path Section -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Label Content="Game Directory"/>
                <DockPanel>
                    <Button x:Name="BtnBrowse"
                        Content="Browse"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Padding="12,6"
                        Click="BtnBrowse_Click"/>
                    <TextBox x:Name="TxtGamePath"
                         IsReadOnly="True"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Ellipse x:Name="StatusDot"
                         Width="10" Height="10"
                         Fill="{StaticResource WarningOrange}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtInstallStatus"
                           Text="Not Installed"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Separator -->
            <Rectangle Grid.Row="3"
                   Height="1"
                   Fill="{StaticResource BorderColor}"
                   Margin="0,4,0,12"/>

            <!-- Network Settings -->
            <StackPanel Grid.Row="4">
                <Label Content="NETWORK SETTINGS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,8"/>

                <!-- Connection Type -->
                <Label Content="Connection Type"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbSteam"
                             Content="Steam"
                             GroupName="Transport"
                             IsChecked="True"
                             Margin="0,0,20,0"
                             Checked="Transport_Changed"/>
                    <RadioButton x:Name="RbDirectIP"
                             Content="Direct IP"
                             GroupName="Transport"
                             Checked="Transport_Changed"/>
                </StackPanel>

                <!-- Direct IP Settings (hidden when Steam) -->
                <StackPanel x:Name="PnlDirectIP" Visibility="Collapsed">
                    <!-- Role -->
                    <Label Content="Role"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="RbHost"
                                 Content="Host"
                                 GroupName="Role"
                                 IsChecked="True"
                                 Margin="0,0,20,0"
                                 Checked="Role_Changed"/>
                        <RadioButton x:Name="RbClient"
                                 Content="Client"
                                 GroupName="Role"
                                 Checked="Role_Changed"/>
                    </StackPanel>

                <!-- Host IP -->
                <Label Content="Host IP"/>
                <TextBox x:Name="TxtHostIP"
                         Text="0.0.0.0"
                         TextChanged="TxtHostIP_TextChanged"
                         IsEnabled="False"
                         Margin="0,0,0,12"/>

                    <!-- Port -->
                    <Label Content="Port"/>
                    <TextBox x:Name="TxtPort"
                         Text="7777"
                         TextChanged="TxtPort_TextChanged"
                         Margin="0,0,0,12"/>

                    <!-- Auto-connect -->
                    <CheckBox x:Name="ChkAutoConnect"
                          Content="Auto-connect on launch"
                          Margin="0,0,0,4"/>
                </StackPanel>

                <!-- Game Settings -->
                <Rectangle Height="1"
                       Fill="{StaticResource BorderColor}"
                       Margin="0,8,0,12"/>

                <Label Content="GAME SETTINGS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,8"/>

                <CheckBox x:Name="ChkTimeVote"
                      Content="Time compression voting (both players must agree)"
                      Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Buttons -->
            <DockPanel Grid.Row="6" Margin="0,12,0,0">
                <Button x:Name="BtnLaunch"
                    Content="Launch Game"
                    DockPanel.Dock="Right"
                    Padding="24,10"
                    IsEnabled="False"
                    Click="BtnLaunch_Click"/>
                <Button x:Name="BtnInstall"
                    Content="Install"
                    Padding="24,10"
                    Margin="0,0,12,0"
                    Click="BtnInstall_Click"/>
                <Button x:Name="BtnFeedback"
                    Content="Send Feedback"
                    Padding="24,10"
                    Margin="0,0,12,0"
                    Click="BtnFeedback_Click"/>
            </DockPanel>

            <!-- Status Bar -->
            <Border Grid.Row="7"
                Background="{StaticResource SecondaryBg}"
                CornerRadius="4"
                Padding="10,6"
                Margin="0,12,0,0">
                <TextBlock x:Name="TxtStatus"
                       Text="Ready"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
